<!-- Admin Components -->
<circuit access="public">

	<fuseaction name="initialize">
		<instantiate object="control" class="AdminComponents_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="initialize()" />
	</fuseaction>
	
	<fuseaction name="getGridData">
		<instantiate object="control" class="AdminComponents_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="getGridData()" />
	</fuseaction>
	
	<fuseaction name="addDisplay">
		<instantiate object="control" class="AdminComponents_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="componentTypesAddDisplay()" />
	</fuseaction>

	<fuseaction name="add">
		<instantiate object="control" class="AdminComponents_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="componentsAdd()" />
	</fuseaction>

    <fuseaction name="editDisplay">
		<instantiate object="control" class="AdminComponents_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="componentsEditDisplay()" />
	</fuseaction>

    <fuseaction name="edit">
		<instantiate object="control" class="AdminComponents_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="componentsEdit()" />
	</fuseaction>

	<fuseaction name="delete">
		<instantiate object="control" class="AdminComponents_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="componentsDelete()" />
	</fuseaction>
	
	<fuseaction name="activate">
		<instantiate object="control" class="AdminComponents_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="componentTypesActivate()" />
	</fuseaction>

	<fuseaction name="getPreviewImage">
		<instantiate object="control" class="AdminComponents_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="getPreviewImage() " />
	</fuseaction>
	
	<fuseaction name="uploadPreviewImage">
		<instantiate object="control" class="AdminComponents_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="uploadPreviewImage()" />
	</fuseaction>

</circuit>
