<!-- Admin Sites / Site Groups -->
<circuit access="public">

	<fuseaction name="initialize">
		<instantiate object="control" class="AdminSitesSiteGroups_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="initialize()" />
	</fuseaction>
	
	<fuseaction name="getGridData">
		<instantiate object="control" class="AdminSitesSiteGroups_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="getGridData()" />
	</fuseaction>
	
	<fuseaction name="addDisplay">
		<instantiate object="control" class="AdminSitesSiteGroups_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="siteGroupAddDisplay()" />
	</fuseaction>

	<fuseaction name="add">
		<instantiate object="control" class="AdminSitesSiteGroups_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="siteGroupAdd()" />
	</fuseaction>

    <fuseaction name="editDisplay">
		<instantiate object="control" class="AdminSitesSiteGroups_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="siteGroupEditDisplay()" />
	</fuseaction>

    <fuseaction name="edit">
		<instantiate object="control" class="AdminSitesSiteGroups_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="siteGroupEdit()" />
	</fuseaction>

	<fuseaction name="delete">
		<instantiate object="control" class="AdminSitesSiteGroups_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="siteGroupsDelete()" />
	</fuseaction>

</circuit>
