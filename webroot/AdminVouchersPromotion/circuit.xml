<!-- Admin Vouchers Promotion -->
<circuit access="public">

	<fuseaction name="initialize">
		<instantiate object="control" class="AdminVouchersPromotion_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="initialize()" />
	</fuseaction>

	<fuseaction name="promotionActivate">
		<instantiate object="control" class="AdminVouchersPromotion_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="promotionActivate()" />
	</fuseaction>

	<fuseaction name="addDisplay">
		<instantiate object="control" class="AdminVouchersPromotion_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="promotionAddDisplay()" />
	</fuseaction>

	<fuseaction name="add">
		<instantiate object="control" class="AdminVouchersPromotion_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="promotionAdd()" />
	</fuseaction>

    <fuseaction name="editDisplay">
		<instantiate object="control" class="AdminVouchersPromotion_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="promotionEditDisplay()" />
	</fuseaction>

    <fuseaction name="edit">
		<instantiate object="control" class="AdminVouchersPromotion_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="promotionEdit()" />
	</fuseaction>

	<fuseaction name="delete">
		<instantiate object="control" class="AdminVouchersPromotion_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="promotionDelete()" />
	</fuseaction>

	<fuseaction name="listPromotions">
		<instantiate object="control" class="AdminVouchersPromotion_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="listPromotions()" />
	</fuseaction>

</circuit>
