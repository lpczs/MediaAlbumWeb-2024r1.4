<!-- Admin Taopix Online / Data Retention Policies Admin -->
<circuit access="public">

	<fuseaction name="initialize">
		<instantiate object="control" class="AdminDataRetentionAdmin_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="initialize()" />
	</fuseaction>

	<fuseaction name="getGridData">
		<instantiate object="control" class="AdminDataRetentionAdmin_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="getGridData()" />
	</fuseaction>

	<fuseaction name="addDisplay">
		<instantiate object="control" class="AdminDataRetentionAdmin_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="dataPolicyAddDisplay()" />
	</fuseaction>

	<fuseaction name="add">
		<instantiate object="control" class="AdminDataRetentionAdmin_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="dataPolicyAdd()" />
	</fuseaction>

    <fuseaction name="editDisplay">
		<instantiate object="control" class="AdminDataRetentionAdmin_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="dataPolicyEditDisplay()" />
	</fuseaction>

    <fuseaction name="edit">
		<instantiate object="control" class="AdminDataRetentionAdmin_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="dataPolicyEdit()" />
	</fuseaction>

	<fuseaction name="delete">
		<instantiate object="control" class="AdminDataRetentionAdmin_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="dataPolicyDelete()" />
	</fuseaction>

	<fuseaction name="setPolicyActiveStatus">
		<instantiate object="control" class="AdminDataRetentionAdmin_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="setPolicyActiveStatus()" />
	</fuseaction>

</circuit>
