<!-- Admin Component Categories -->
<circuit access="public">

	<fuseaction name="initialize">
		<instantiate object="control" class="AdminComponentCategories_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="initialize()" />
	</fuseaction>
	
	<fuseaction name="getGridData">
		<instantiate object="control" class="AdminComponentCategories_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="getGridData()" />
	</fuseaction>
	
	<fuseaction name="addDisplay">
		<instantiate object="control" class="AdminComponentCategories_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="componentCategoriesAddDisplay()" />
	</fuseaction>

	<fuseaction name="add">
		<instantiate object="control" class="AdminComponentCategories_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="componentCategoriesAdd()" />
	</fuseaction>

    <fuseaction name="editDisplay">
		<instantiate object="control" class="AdminComponentCategories_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="componentCategoriesEditDisplay()" />
	</fuseaction>

    <fuseaction name="edit">
		<instantiate object="control" class="AdminComponentCategories_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="componentCategoriesEdit()" />
	</fuseaction>

	<fuseaction name="delete">
		<instantiate object="control" class="AdminComponentCategories_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="componentCategoriesDelete()" />
	</fuseaction>
	
	<fuseaction name="activate">
		<instantiate object="control" class="AdminComponentCategories_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="componentCategoriesActivate()" />
	</fuseaction>

</circuit>
