<!-- Admin Customers -->
<circuit access="public">

	<fuseaction name="initialize">
		<instantiate object="control" class="AdminCustomers_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="initialize()" />
	</fuseaction>

	<fuseaction name="customerActivate">
		<instantiate object="control" class="AdminCustomers_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="customerActivate()" />
	</fuseaction>

	<fuseaction name="addDisplay">
		<instantiate object="control" class="AdminCustomers_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="customerAddDisplay()" />
	</fuseaction>

	<fuseaction name="customerList">
		<instantiate object="control" class="AdminCustomers_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="customerList()" />
	</fuseaction>

	<fuseaction name="add">
		<instantiate object="control" class="AdminCustomers_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="customerAdd()" />
	</fuseaction>

    <fuseaction name="editDisplay">
		<instantiate object="control" class="AdminCustomers_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="customerEditDisplay()" />
	</fuseaction>

    <fuseaction name="edit">
		<instantiate object="control" class="AdminCustomers_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="customerEdit()" />
	</fuseaction>

	<fuseaction name="delete">
		<instantiate object="control" class="AdminCustomers_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="customerDelete()" />
	</fuseaction>

	<fuseaction name="redact">
		<instantiate object="control" class="AdminCustomers_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="customerRedact()" />
	</fuseaction>

	<fuseaction name="redactdecline">
		<instantiate object="control" class="AdminCustomers_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="customerRedactDecline()" />
	</fuseaction>

	<fuseaction name="exportDisplay">
		<instantiate object="control" class="AdminCustomers_control" />
		<invoke object="control" methodcall="assertRequestMethod(['GET'])" />
		<invoke object="control" methodcall="customerExportDisplay()" />
	</fuseaction>

	<fuseaction name="export">
		<instantiate object="control" class="AdminCustomers_control" />
		<invoke object="control" methodcall="assertRequestMethod(['POST'])" />
		<invoke object="control" methodcall="assertCsrfToken()" />
		<invoke object="control" methodcall="customerExport()" />
	</fuseaction>
</circuit>
